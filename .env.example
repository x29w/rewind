# Root .env.example for Rewind Monorepo
# Copy this file to .env.local and fill in your values

# ============================================
# Server Configuration
# ============================================

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/rewind?schema=public"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV="development"

# ============================================
# Dashboard Configuration
# ============================================

# API Base URL (for Dashboard to connect to Server)
VITE_API_BASE_URL="http://localhost:3000"

# ============================================
# Optional Features
# ============================================

# AI Analysis
AI_ENABLED="true"
OPENAI_API_KEY=""
GEMINI_API_KEY=""
GROQ_API_KEY=""

# Email Alerts
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# Webhook Alerts
FEISHU_WEBHOOK_URL=""
DINGTALK_WEBHOOK_URL=""
SLACK_WEBHOOK_URL=""

# ============================================
# Storage & Data
# ============================================

SOURCEMAP_STORAGE_PATH="./storage/sourcemaps"
DATA_RETENTION_DAYS=90

# ============================================
# Rate Limiting
# ============================================

RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=1000

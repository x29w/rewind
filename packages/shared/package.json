{
  "name": "@rewind-dev/shared",
  "version": "0.1.0",
  "description": "Shared type definitions for Rewind project",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "rewind",
    "types",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}

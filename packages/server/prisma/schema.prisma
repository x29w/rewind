// Prisma Schema for Rewind Server
// Rewind 服务端数据库模型
// Rewind サーバーデータベースモデル
// Rewind 伺服器資料庫模型

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Application model
// 应用模型
// アプリケーションモデル
// 應用模型
model App {
  id        String   @id @default(cuid())
  name      String
  apiKey    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issues Issue[]
  events Event[]

  @@map("apps")
}

// Issue model
// 问题模型
// 問題モデル
// 問題模型
model Issue {
  id          String   @id @default(cuid())
  fingerprint String
  type        String
  level       String
  status      String   @default("open")
  title       String
  message     String   @db.Text
  stack       String?  @db.Text
  eventCount  Int      @default(1)
  userCount   Int      @default(1)
  firstSeen   DateTime @default(now())
  lastSeen    DateTime @default(now())
  appId       String
  appVersion  String?
  environment String?
  tags        Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  app    App     @relation(fields: [appId], references: [id])
  events Event[]

  // Unique constraint
  @@unique([appId, fingerprint])
  // Performance indexes
  // 性能优化索引
  @@index([appId, status])
  @@index([appId, lastSeen(sort: Desc)])
  @@index([fingerprint])
  @@index([level])
  @@index([type])
  @@index([appId, status, lastSeen(sort: Desc)])
  @@map("issues")
}

// Event model
// 事件模型
// イベントモデル
// 事件模型
model Event {
  id          String   @id @default(cuid())
  issueId     String
  eventData   Json
  breadcrumbs Json
  device      Json
  network     Json?
  userId      String?
  sessionId   String
  pageUrl     String
  appId       String
  createdAt   DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id])
  app   App   @relation(fields: [appId], references: [id])

  // Performance indexes
  // 性能优化索引
  @@index([issueId])
  @@index([appId, createdAt(sort: Desc)])
  @@index([sessionId])
  @@index([userId])
  @@index([issueId, createdAt(sort: Desc)])
  @@map("events")
}

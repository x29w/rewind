# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/rewind?schema=public"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV="development"

# AI (Optional)
AI_ENABLED="true"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4"
GEMINI_API_KEY=""
GROQ_API_KEY=""

# Alert (Optional)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# Webhook URLs (Optional)
FEISHU_WEBHOOK_URL=""
DINGTALK_WEBHOOK_URL=""
SLACK_WEBHOOK_URL=""

# Storage
SOURCEMAP_STORAGE_PATH="./storage/sourcemaps"

# Data Retention
DATA_RETENTION_DAYS=90

# Rate Limiting
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=1000

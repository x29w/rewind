{
  "name": "@rewind-dev/sdk",
  "version": "0.1.0",
  "description": "Rewind SDK for browser error tracking and monitoring",
  "main": "dist/rewind.cjs.js",
  "module": "dist/rewind.esm.js",
  "browser": "dist/rewind.umd.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c --watch",
    "dev": "rollup -c --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "biome check ."
  },
  "keywords": [
    "error-tracking",
    "monitoring",
    "sdk",
    "browser",
    "frontend"
  ],
  "author": "Rewind Team",
  "license": "MIT",
  "dependencies": {
    "@rewind-dev/shared": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "rollup": "^4.30.1",
    "tslib": "^2.8.1",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}

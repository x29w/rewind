{
  "enabled": true,
  "name": "读取会话记忆",
  "description": "Automatically read conversation memory file before responding to maintain context continuity",
  "version": "1",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Before responding, check if CONVERSATION_MEMORY.md exists and read it to understand the project context, completed tasks, and current status. Use this information to provide contextually aware responses."
  },
  "workspaceFolderName": "Rewind",
  "shortName": "load-conversation-memory"
}
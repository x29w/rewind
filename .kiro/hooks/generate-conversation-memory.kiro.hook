{
  "enabled": true,
  "name": "Generate Conversation Memory",
  "description": "Generate conversation memory document to record current project state, completed tasks, TODOs, etc., for context recovery in new conversations",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Please generate a complete conversation memory document (CONVERSATION_MEMORY.md) with the following content:\n\n1. **Project Overview**: Brief description of what Rewind project is, core features\n2. **Current Status**:\n   - Completed tasks and files\n   - Current development phase (P0-a/P0-b, etc.)\n   - Recent important decisions and changes\n3. **Directory Structure**: Complete project directory tree\n4. **Tech Stack**: Technologies and tools used\n5. **Development Standards**: Key code standard points\n6. **TODO Items**:\n   - What to do next\n   - Incomplete Specs\n   - Known issues and TODOs\n7. **Important File Index**: List key files with paths and purposes\n8. **Context Hints**: Key information needed when starting new conversations\n\nFormat requirements: Use Markdown, clear structure, easy to read and understand quickly. Save to CONVERSATION_MEMORY.md in project root after generation."
  },
  "workspaceFolderName": "Rewind",
  "shortName": "generate-conversation-memory"
}

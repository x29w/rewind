# Rewind Project .gitignore

# ============================================
# Dependencies
# ============================================
node_modules/
.pnp
.pnp.js

# ============================================
# Build Outputs
# ============================================
dist/
build/
out/
.next/
.nuxt/
.cache/

# SDK specific
packages/sdk/dist/

# Server specific
packages/server/dist/

# Dashboard specific
packages/dashboard/dist/

# ============================================
# Environment Variables
# ============================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# Testing
# ============================================
coverage/
.nyc_output/
*.lcov
.vitest/

# ============================================
# IDE & Editors
# ============================================
# VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# ============================================
# OS Files
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ============================================
# Database
# ============================================
*.sqlite
*.sqlite3
*.db

# PostgreSQL
*.pgsql

# ============================================
# Prisma
# ============================================
# Keep migrations but ignore generated client
packages/server/node_modules/.prisma/
packages/server/prisma/migrations/*_draft/

# ============================================
# Redis
# ============================================
dump.rdb

# ============================================
# Temporary Files
# ============================================
tmp/
temp/
*.tmp
*.temp

# ============================================
# Package Manager
# ============================================
# pnpm
.pnpm-store/
.pnpm-debug.log

# npm
package-lock.json

# yarn
yarn.lock
.yarn/
.yarn-integrity

# ============================================
# Turborepo
# ============================================
.turbo/

# ============================================
# TypeScript
# ============================================
*.tsbuildinfo

# Compiled JS files in TypeScript source directories
# (These should not be committed - only dist/ should contain compiled output)
packages/*/src/**/*.js
packages/*/src/**/*.jsx

# TanStack Router auto-generated files
packages/dashboard/src/routeTree.gen.ts
packages/dashboard/src/routeTree.gen.js

# ============================================
# Sourcemaps (production)
# ============================================
# Keep sourcemaps in development, ignore in production builds
*.map

# ============================================
# Uploads & User Data
# ============================================
uploads/
user-data/

# ============================================
# SourceMaps Storage (Server)
# ============================================
packages/server/sourcemaps/

# ============================================
# SSL Certificates
# ============================================
*.pem
*.key
*.crt
*.cert

# ============================================
# Docker
# ============================================
docker-compose.override.yml

# ============================================
# Backup Files
# ============================================
*.bak
*.backup
*.old

# ============================================
# Project Specific
# ============================================
# Kiro hooks (not needed for this project)
.kiro/hooks/

# Conversation memory (auto-generated by Kiro)
CONVERSATION_MEMORY.md

# Local development notes
NOTES.md
TODO.local.md
CURRENT_TASKS.md
CHANGELOG.md

# Test data
test-data/
mock-data/

# ============================================
# CI/CD
# ============================================
.github/workflows/*.local.yml

# ============================================
# Documentation Build
# ============================================
docs/.vitepress/dist/
docs/.vitepress/cache/

# ============================================
# Keep These Files
# ============================================
# Important: Do NOT ignore these
!.gitignore
!.gitkeep
!.npmrc
!.nvmrc
!.editorconfig

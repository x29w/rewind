{
  "name": "rewind",
  "version": "0.1.0",
  "private": true,
  "description": "An intelligent frontend monitoring platform that helps developers quickly locate and reproduce production issues",
  "keywords": [
    "frontend-monitoring",
    "error-tracking",
    "observability",
    "typescript",
    "monorepo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/X29w/rewind.git"
  },
  "license": "MIT",
  "author": "Rewind Team",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:server": "turbo dev --filter=@rewind-dev/server",
    "dev:dashboard": "turbo dev --filter=@rewind-dev/dashboard",
    "build": "turbo build",
    "build:sdk": "turbo build --filter=@rewind-dev/sdk",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "turbo test",
    "test:e2e": "cd packages/dashboard && pnpm test:e2e",
    "test:e2e:ui": "cd packages/dashboard && pnpm test:e2e:ui",
    "test:e2e:install": "cd packages/dashboard && pnpm test:install",
    "type-check": "turbo type-check",
    "clean": "turbo clean && rm -rf node_modules",
    "deploy:verify": "chmod +x scripts/deploy-verify.sh && ./scripts/deploy-verify.sh",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "docker:logs": "docker-compose logs -f"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.0.0",
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.15.0"
  },
  "packageManager": "pnpm@9.15.0"
}
